# VPN + SSH credentials — chmod 600, NEVER commit this file to any repo.
# Fill in the placeholders, then run `vpn` / `ssh-connect`.

# --- NetExtender VPN ---
VPN_SERVER="vpn.example.com:443"   # SSL VPN server (host or host:port)
VPN_USER="CHANGEME"
VPN_PASS="CHANGEME"
VPN_DOMAIN="LocalDomain"           # SonicWall domain (GUI shows it on the login form)

# --- SSH ---
SSH_PASS="CHANGEME"                # default password for the work boxes
# Per-host override (host with . and - replaced by _), e.g.:
# SSH_PASS_141htaaprd2="different-password"
